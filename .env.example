# Copy to .env and fill in values. Never commit .env to version control.

# Backend API base URL
# Local dev (outside Docker):  http://localhost:8000/api
# Docker dev:                  http://localhost:8001/api
# Production:                  /api  (nginx handles routing, no domain needed)
VITE_API_BASE_URL=http://localhost:8001/api

# Firebase (push notifications)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=
